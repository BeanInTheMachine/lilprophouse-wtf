# ============================================
# Prop House — Environment Variables
# ============================================
# Copy this file to .env and fill in the blanks.
#   cp .env.example .env
# ============================================

# -------------------------------------------
# 1. DATABASE (REQUIRED)
# -------------------------------------------
# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:password@localhost:5432/prop_house?schema=public"

# -------------------------------------------
# 2. WALLETCONNECT (REQUIRED for RainbowKit)
# -------------------------------------------
# Create a free project at https://cloud.walletconnect.com
# Without this, the wallet connection modal will not function.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# -------------------------------------------
# 3. RPC PROVIDER (RECOMMENDED)
# -------------------------------------------
# The HTTP JSON-RPC endpoint for Ethereum mainnet.
# Without this, wagmi falls back to the public viem endpoint which is
# rate-limited and unsuitable for production.
#
# Choose ONE of the following or provide your own:
#   Alchemy:   https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
#   Infura:    https://mainnet.infura.io/v3/YOUR_KEY
#   QuickNode: https://YOUR_NAME.quiknode.pro/YOUR_KEY
NEXT_PUBLIC_RPC_URL=

# -------------------------------------------
# 4. API BASE URL (OPTIONAL — defaults to relative paths)
# -------------------------------------------
# Only set this if the Next.js API routes are hosted on a different
# domain than the frontend. Leave empty for same-origin deployments.
NEXT_PUBLIC_API_URL=

# -------------------------------------------
# 5. SUPABASE (OPTIONAL — comments/replies)
# -------------------------------------------
# Only required if you enable the proposal comments feature.
# Create a free project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -------------------------------------------
# 6. IPFS / PINATA (OPTIONAL — file uploads)
# -------------------------------------------
# Required for proposal image/file uploads to IPFS.
# Create a free account at https://pinata.cloud
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=

# -------------------------------------------
# 7. ANALYTICS (OPTIONAL)
# -------------------------------------------
# Google Analytics Measurement ID. Leave empty to disable.
NEXT_PUBLIC_ANALYTICS_ID=

# -------------------------------------------
# 8. SITE URL (RECOMMENDED for OG images)
# -------------------------------------------
# The public URL where the site is hosted. Used by OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=https://prop.house

# -------------------------------------------
# 9. SMART CONTRACTS (Mainnet — Prop House Protocol)
# -------------------------------------------
# These are the deployed Prop House protocol contract addresses on Ethereum mainnet.
# Change these if deploying your own contracts or testing on a testnet.
NEXT_PUBLIC_PROP_HOUSE_ADDRESS=0x000000002C93CAD6F9cFD00C603aEf62458d8A48
NEXT_PUBLIC_COMMUNITY_HOUSE_IMPL=0x92eE1cCdf3AA2E39E3F519B95fee2A601A28663D
NEXT_PUBLIC_TIMED_ROUND_IMPL=0x43c015Df7f3868B287ad94D88b1E05F596BBa453
NEXT_PUBLIC_CREATOR_PASS_ISSUER_ADDRESS=0x392d429Dfa457C216C35fc6EBaf34c42de4aEAB5
